{
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "target": "ESNext",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "strict": true,
    "types": ["vite/client"],
    "baseUrl": "./",
    "paths": {
      "@/*": ["./src/*"],
      ":idp-code/infra": ["../../packages/infra/src/index.ts"],
      ":idp-code/common-constructs": [
        "../../packages/common/constructs/src/index.ts"
      ]
    }
  }
}
