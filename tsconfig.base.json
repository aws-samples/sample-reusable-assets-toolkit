{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@idp-code/source"],
    "rootDir": ".",
    "paths": {
      ":idp-code/infra": ["./packages/infra/src/index.ts"],
      ":idp-code/common-constructs": [
        "./packages/common/constructs/src/index.ts"
      ]
    }
  }
}
